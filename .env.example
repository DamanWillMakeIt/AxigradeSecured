# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (both Prisma and raw MongoClient use this)
DATABASE_URL="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/axigrade?retryWrites=true&w=majority"

# ── Auth & Encryption (REQUIRED — app will crash on startup if missing) ───────
# Generate SESSION_SECRET with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="CHANGE_ME_64_char_hex_string"

# Generate ENCRYPTION_KEY with: openssl rand -hex 32
# Used to encrypt API keys at rest in the database (AES-256-GCM)
ENCRYPTION_KEY="CHANGE_ME_64_char_hex_string"

# ── Upstash Redis (REQUIRED for production rate limiting) ─────────────────────
# Create free database at https://upstash.com
# Required for production-grade rate limiting across serverless instances
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token_here"

# ── Cloudinary (image & video reference uploads) ──────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── Gemini (scene-modify) ─────────────────────────────────────────────────────
GEMINI_API_KEY="your_gemini_api_key"

# ── xAI / Grok ────────────────────────────────────────────────────────────────
# NOTE: xAI keys are user-supplied at runtime via the UI — NOT stored here.
# Users enter their own key in the Architect / Visual Hook key panel each session.

# ── Node environment ──────────────────────────────────────────────────────────
NODE_ENV="development"


# ── Tool Credits (default: 25 each) ──────────────────────────────────────────
# Change any of these in Vercel env vars to adjust credits per tool without redeploying
CREDITS_ARCHITECT=25
CREDITS_ALGORITHM_WHISPERER=25
CREDITS_QUALITY_CRITIC=25
CREDITS_VISUAL_HOOK=25
CREDITS_CLICK_ENGINEER=25
CREDITS_SCENE_MODIFY=25
